# Copy this file to .env and fill in values
# Local development uses these defaults

# ----- Database (Prisma) -----
# Local dev: SQLite file in repo
DATABASE_URL="file:/Users/youruser/reformaflow/prisma/dev.db"
# Production (Fly.io volume mount): "file:/data/dev.db"

# ----- API: secrets -----
# Generate a strong random secret:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"

# Initial admin (created idempotently on every boot)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"

# ----- API: optional features -----
GEMINI_API_KEY=""

# ----- API: cross-origin -----
# Local dev: just the web origin
CORS_ORIGIN="http://localhost:3000"
# Production: Vercel domain(s), comma-separated for previews:
# CORS_ORIGIN="https://reformaflow.vercel.app,https://reformaflow-git-main-yourname.vercel.app"

# ----- API: file uploads -----
# Default: ./uploads (relative to cwd). On Fly.io with volume: "/data/uploads"
# UPLOADS_DIR=""

# ----- Web: where to reach the API -----
# Local dev:
NEXT_PUBLIC_API_URL="http://localhost:3001"
# Production: NEXT_PUBLIC_API_URL="https://reformaflow-api.fly.dev"

# ----- Web: when running on Vercel -----
# (set in the Vercel dashboard, not here)

# ── Agente Financeiro (LLM) ──────────────────────────────────────────────
# Provider: 'ollama' (local, dev) ou 'groq' (hosted grátis, prod)
AGENT_LLM_PROVIDER="ollama"
# Override do modelo (opcional). Defaults: ollama=qwen2.5:7b-instruct, groq=llama-3.3-70b-versatile
AGENT_MODEL=""
# Ollama (dev) — base da API OpenAI-compatível
OLLAMA_BASE_URL="http://localhost:11434/v1"
# Groq (prod) — chave do free tier
GROQ_API_KEY=""

# ── VibeVoice (TTS do Copiloto) ────────────────────────────────────────────
# Suba o backend VibeVoice (demo websocket) antes de usar o botão "Ouvir":
#   python demo/vibevoice_realtime_demo.py --model_path microsoft/VibeVoice-Realtime-0.5B --device mps --port 3010
# Endpoint websocket do backend VibeVoice:
VIBEVOICE_WS_URL="ws://127.0.0.1:3010/stream"
# Voz padrão (opcional). Use /config do VibeVoice para listar presets disponíveis.
VIBEVOICE_DEFAULT_VOICE="pt-Spk1_man"
# Timeout de síntese (ms)
VIBEVOICE_TIMEOUT_MS="30000"
