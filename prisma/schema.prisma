// ReformaFlow — Schema Prisma
// Multi-tenant: todo modelo tem tenantId (exceto Tenant)
// Soft delete: deletedAt em todas as entidades
// Valores monetários em centavos (Int)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String    @id @default(cuid())
  name      String
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users    User[]
  projects Project[]
  agentDailyQuotas AgentDailyQuota[]
  demoSeeds DemoSeed[]

  @@map("tenants")
}

model User {
  id                  String    @id @default(cuid())
  tenantId            String    @map("tenant_id")
  externalId          String?   @unique @map("external_id")
  username            String
  email               String?   @unique @map("email")
  name                String
  role                String    @default("USER")
  isGuest             Boolean   @default(false) @map("is_guest")
  passwordHash        String?   @map("password_hash")
  allowedModules      String    @default("[]") @map("allowed_modules")
  allowedProjects     String    @default("[]") @map("allowed_projects") // IDs de projetos liberados (JSON). Vazio = sem restrição por projeto (vê por tipo/módulo). Não-vazio = só estes projetos.
  allowedProjectTypes String    @default("[]") @map("allowed_project_types") // Tipos de projeto que o usuário pode CRIAR (JSON). Vazio = sem restrição (deriva dos módulos, como hoje). Não-vazio = só estes tipos.
  createdByUserId     String?   @map("created_by_user_id") // Id do admin que criou este usuário. Nulo = auto-cadastro (owner/guest).
  sessionVersion      Int       @default(0) @map("session_version") // Incrementado no force-logout; JWTs com sv antigo são rejeitados
  lastLoginAt         DateTime? @map("last_login_at")
  lastActivityAt      DateTime? @map("last_activity_at") // Última requisição autenticada (atualizado no JWT validate, debounced 5min)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, username])
  @@map("users")
}

model AgentDailyQuota {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  dayKey    String    @map("day_key")
  count     Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, dayKey])
  @@map("agent_daily_quotas")
}

model DemoSeed {
  id               String    @id @default(cuid())
  tenantId         String    @unique @map("tenant_id")
  version          Int
  status           String
  personalProjectId String?   @map("personal_project_id")
  reformaProjectId  String?   @map("reforma_project_id")
  errorMessage     String?   @map("error_message")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("demo_seeds")
}

model Project {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  createdByUserId String? @map("created_by_user_id")
  type        String    @default("REFORMA") // REFORMA | COMPRA | CASA | CARRO | PESSOAL
  name        String
  description String?
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant                  Tenant             @relation(fields: [tenantId], references: [id])
  rooms                   Room[]
  receipts                Receipt[]
  expenses                Expense[]
  cashFlow                CashFlowEntry[]
  simulationValues        SimulationValue[]
  simulations             Simulation[]
  floorPlans              FloorPlan[]
  recurringBills          RecurringBill[]
  maintenanceLogs         MaintenanceLog[]
  reminders               Reminder[]
  carInfo                 CarInfo?
  vehicleDocuments        VehicleDocument[]
  scheduleConfig          ScheduleConfig?
  scheduleStages          ScheduleStage[]
  scheduleTasks           ScheduleTask[]
  scheduleHolidays        ScheduleHoliday[]
  creditCards             CreditCard[]
  bankAccounts            BankAccount[]
  budgetAllocationsSource BudgetAllocation[] @relation("SourceAllocations")
  budgetAllocationsTarget BudgetAllocation[] @relation("TargetAllocations")
  categoryBudgets         CategoryBudget[]
  pendencias              Pendencia[]
  plants                  Plant[]
  invoiceAdjustments      InvoiceAdjustment[]
  priceMonitorItems       PriceMonitorItem[]
  financing               Financing?
  purchaseScenarios       PurchaseScenario[]

  @@map("projects")
}

model CarInfo {
  id              String   @id @default(cuid())
  projectId       String   @unique @map("project_id")
  tenantId        String   @map("tenant_id")
  marca           String?
  modelo          String?
  anoFabricacao   Int?     @map("ano_fabricacao")
  anoModelo       Int?     @map("ano_modelo")
  cor             String?
  placa           String?
  tabelaFipe      Int?     @map("tabela_fipe") // centavos
  valorPago       Int?     @map("valor_pago") // centavos
  kmAtual         Int?     @map("km_atual")
  kmUltimaRevisao Int?     @map("km_ultima_revisao")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])

  @@map("car_info")
}

model Room {
  id        String    @id @default(cuid())
  projectId String    @map("project_id")
  name      String
  order     Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  project        Project         @relation(fields: [projectId], references: [id])
  expenses       Expense[]
  roomImages     RoomImage[]
  floorPlanRooms FloorPlanRoom[]
  pendencias     Pendencia[]

  @@unique([projectId, name])
  @@map("rooms")
}

// ─── Recebimentos ───────────────────────────────────────────

model Receipt {
  id              String    @id @default(cuid())
  projectId       String    @map("project_id")
  tenantId        String    @map("tenant_id")
  valor           Int // centavos
  data            DateTime
  tipo            String // PAGAMENTO | BONUS | VENDA_ACAO | ORCAMENTO_INICIAL | RENDIMENTO | TRANSFERENCIA | OUTROS
  status          String    @default("PREVISTO") // PREVISTO | EM_CAIXA
  descricao       String? // texto livre (descrição do crédito do extrato)
  importId        String?   @map("import_id") // ref BankStatementImport — opcional
  externalId      String?   @map("external_id") // hash idempotente da transação importada
  bankLast4       String?   @map("bank_last4") // últimos 4 da conta bancária de origem
  linkedReceiptId String?   @map("linked_receipt_id") // quando importado do extrato é vinculado a recebimento planejado de outro projeto (evita dupla contagem)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  project           Project            @relation(fields: [projectId], references: [id])
  cashFlow          CashFlowEntry[]
  budgetAllocations BudgetAllocation[]

  @@index([projectId, externalId])
  @@index([linkedReceiptId])
  @@map("receipts")
}

// ─── Despesas ───────────────────────────────────────────────

model Expense {
  id                 String    @id @default(cuid())
  projectId          String    @map("project_id")
  tenantId           String    @map("tenant_id")
  createdByUserId    String?   @map("created_by_user_id")
  tipoDespesa        String    @map("tipo_despesa") // MATERIAL_CONSTRUCAO | ELETRODOMESTICO | REVESTIMENTO | ILUMINACAO | MARMORE | VIDRACARIA_SERRALHERIA | METAL_CERAMICA | MARCENARIA | MAO_DE_OBRA
  categoriaMaoDeObra String?   @map("categoria_mao_de_obra") // EMPREITEIRO | INSTALADOR_PISO | INSTALADOR_MARMORE | PINTOR | ELETRICISTA | VIDRACEIRO | SERRALHEIRO | MARCENEIRO
  roomId             String?   @map("room_id") // ambiente da casa (opcional)
  valor              Int // valor unitário em centavos
  quantidade         Int       @default(1)
  valorTotal         Int       @map("valor_total") // calculado server-side: valor * quantidade
  titulo             String?
  fornecedor         String?
  link               String?
  imageUrl           String?   @map("image_url") // URL direta da imagem do produto (override manual)
  formaPagamento     String    @map("forma_pagamento") // A_VISTA | PARCELADO | QUINZENAL
  dataPagamento      DateTime? @map("data_pagamento") // quando A_VISTA
  quantidadeParcela  Int?      @map("quantidade_parcela") // quando PARCELADO ou QUINZENAL
  dataInicioParcela  DateTime? @map("data_inicio_parcela") // quando PARCELADO ou QUINZENAL
  dataCompra         DateTime? @map("data_compra") // COMPETÊNCIA: data real da compra (independe do vencimento/parcela). Usada pelo eixo "Gastos Controle". NÃO afeta a Conta Real (eixo caixa), que deriva o vencimento à parte.
  status             String    @default("PLANEJADO") // PLANEJADO | PAGO
  recorrente         Boolean   @default(false) // despesa fixa mensal (ocorrência virtual, não gera linhas)
  recorrenciaFim     DateTime? @map("recorrencia_fim") // último mês da recorrência (null = sem fim)
  paidParcelas       String?   @map("paid_parcelas") // JSON array de índices 0-based de parcelas pagas (PARCELADO/QUINZENAL). null = nenhuma parcial
  plannedExpenseId   String?   @unique @map("planned_expense_id") // ref à despesa planejada que originou esta paga
  settledByExpenseId String?   @unique @map("settled_by_expense_id") // quando esta planejada foi liquidada por uma paga
  importId           String?   @map("import_id") // id da importação de fatura (CreditCardStatementImport) — opcional
  externalId         String?   @map("external_id") // hash idempotente da transação importada
  seriesKey          String?   @map("series_key") // identifica compra parcelada (cardId|merchantNorm|amountPerInstall|total) — para casar parcelas futuras
  cardLast4          String?   @map("card_last4") // últimos 4 do cartão de origem (denormalizado)
  bankLast4          String?   @map("bank_last4") // últimos 4 da conta bancária de origem
  linkedExpenseId    String?   @map("linked_expense_id") // quando importada do cartão é vinculada a despesa de outro projeto (evita dupla contagem)
  settlesInvoiceKey  String?   @map("settles_invoice_key") // quando esta despesa (cobrança cartão-paga-cartão ou PIX) quita a fatura de OUTRO cartão: "{cardLast4}:{dueMonth}"
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  project             Project                  @relation(fields: [projectId], references: [id])
  room                Room?                    @relation(fields: [roomId], references: [id])
  plannedExpense      Expense?                 @relation("ExpenseSettlement", fields: [plannedExpenseId], references: [id])
  settledBy           Expense?                 @relation("ExpenseSettlement")
  cashFlow            CashFlowEntry[]
  markers             FloorPlanMarker[]
  settlementsAsSource CrossProjectSettlement[] @relation("SettlementSource")
  settlementsAsTarget CrossProjectSettlement[] @relation("SettlementTarget")
  rateioAsSource      RateioAllocation[]       @relation("RateioSource")
  rateioAsTarget      RateioAllocation[]       @relation("RateioTarget")
  financingInstallment FinancingInstallment?

  @@index([linkedExpenseId])
  @@index([seriesKey])
  @@map("expenses")
}

model PriceMonitorItem {
  id                  String    @id @default(cuid())
  projectId           String    @map("project_id")
  tenantId            String    @map("tenant_id")
  title               String
  query               String?
  url                 String?   @map("url")
  productUrl          String?   @map("product_url")
  notes               String?
  referencePriceCents Int?      @map("reference_price_cents")
  targetPrice         Float?    @map("target_price")
  targetPriceCents    Int?      @map("target_price_cents")
  isActive            Boolean   @default(true) @map("is_active")
  alertSent           Boolean   @default(false) @map("alert_sent")
  monitoringEndDate   DateTime? @map("monitoring_end_date")
  lastBestPriceCents  Int?      @map("last_best_price_cents")
  lastBestPrice       Float?    @map("last_best_price")
  lastBestStore       String?   @map("last_best_store")
  lastBestLink        String?   @map("last_best_link")
  lastCheckedAt       DateTime? @map("last_checked_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id])
  purchasePlanItems PurchaseScenarioItem[]
  pricePoints PricePoint[]

  @@index([projectId, isActive])
  @@index([tenantId, projectId, title])
  @@index([targetPrice])
  @@index([monitoringEndDate])
  @@map("price_monitor_items")
}

// Histórico de preço: 1 registro por checagem bem-sucedida (scheduler
// horário, "atualizar" manual ou "atualizar todos"). Log append-only —
// nunca soft-deletado (ver modelsWithoutSoftDelete em prisma.service.ts).
// Alimenta o gráfico de histórico do item monitorado (mockup M4).
model PricePoint {
  id                 String   @id @default(cuid())
  tenantId           String   @map("tenant_id")
  priceMonitorItemId String   @map("price_monitor_item_id")
  priceCents         Int      @map("price_cents")
  store              String?
  link               String?
  checkedAt          DateTime @default(now()) @map("checked_at")

  priceMonitorItem PriceMonitorItem @relation(fields: [priceMonitorItemId], references: [id])

  @@index([tenantId, priceMonitorItemId, checkedAt])
  @@map("price_points")
}

model CategoryBudget {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")
  projectId        String    @map("project_id")
  tipoDespesa      String    @map("tipo_despesa")
  mes              String?
  valorLimiteCents Int       @map("valor_limite_cents")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id])

  @@index([tenantId, projectId])
  @@index([tenantId, projectId, tipoDespesa, mes])
  @@map("category_budgets")
}

// ─── Conciliação cross-project por parcela ─────────────────
// Quando uma despesa importada (PESSOAL, cartão/conta) liquida UMA parcela de
// uma despesa planejada em outro projeto (REFORMA/CASA/CARRO). Não-destrutivo:
// guarda o valor real (da fatura) e o snapshot do planejado para unlink reversível.
model CrossProjectSettlement {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  sourceExpenseId String   @map("source_expense_id") // despesa importada (PESSOAL) que liquida
  targetExpenseId String   @map("target_expense_id") // despesa planejada (outro projeto)
  parcelaIndex    Int      @map("parcela_index") // parcela 0-based do ALVO liquidada
  realValor       Int      @map("real_valor") // valor real pago (centavos), da fatura
  plannedValor    Int      @map("planned_valor") // snapshot do valor planejado da parcela (restore)
  plannedStatus   String   @map("planned_status") // snapshot do status original do alvo (PLANEJADO/PAGO)
  createdAt       DateTime @default(now()) @map("created_at")

  source Expense @relation("SettlementSource", fields: [sourceExpenseId], references: [id])
  target Expense @relation("SettlementTarget", fields: [targetExpenseId], references: [id])

  @@unique([targetExpenseId, parcelaIndex])
  @@index([sourceExpenseId])
  @@index([tenantId])
  @@map("cross_project_settlements")
}

// ─── Rateio de compra em N planejadas (cross-project) ──────
// Uma compra parcelada (fonte, PESSOAL) é distribuída entre várias despesas
// planejadas (alvos, outro projeto). Cada alvo recebe uma alocação (centavos);
// a soma das alocações = valorTotal da fonte. O alvo mantém seu valorTotal
// PLANEJADO imutável — o efetivo é o cronograma da FONTE escalado à alocação.
// Não-destrutivo e reversível: guarda snapshot de status/paidParcelas do alvo.
model RateioAllocation {
  id                   String    @id @default(cuid())
  tenantId             String    @map("tenant_id")
  sourceExpenseId      String    @map("source_expense_id") // compra-fonte (PESSOAL)
  targetExpenseId      String    @map("target_expense_id") // planejada (outro projeto)
  allocation           Int // centavos alocados a este alvo
  plannedStatus        String    @map("planned_status") // snapshot do status original do alvo
  plannedPaid          String?   @map("planned_paid") // snapshot do paidParcelas original (JSON)
  // Snapshot do CRONOGRAMA original do alvo (para restaurar no desfazer): quando o
  // rateio sobrescreve o alvo com o cronograma da fonte (Parcelado Nx + datas + valor
  // = alocação), estes campos guardam o estado anterior para o unratearSource restaurar.
  plannedValor         Int?      @map("planned_valor") // valor unitário original (centavos)
  plannedQuantidade    Int?      @map("planned_quantidade")
  plannedValorTotal    Int?      @map("planned_valor_total")
  plannedForma         String?   @map("planned_forma")
  plannedQtdParcela    Int?      @map("planned_qtd_parcela")
  plannedDataInicio    DateTime? @map("planned_data_inicio")
  plannedDataPagamento DateTime? @map("planned_data_pagamento")
  createdAt            DateTime  @default(now()) @map("created_at")

  source Expense @relation("RateioSource", fields: [sourceExpenseId], references: [id])
  target Expense @relation("RateioTarget", fields: [targetExpenseId], references: [id])

  @@unique([targetExpenseId])
  @@index([sourceExpenseId])
  @@index([tenantId])
  @@map("rateio_allocations")
}

// ─── Fluxo de Caixa (auto-gerado) ──────────────────────────

model CashFlowEntry {
  id                 String    @id @default(cuid())
  projectId          String    @map("project_id")
  tenantId           String    @map("tenant_id")
  receiptId          String?   @map("receipt_id")
  expenseId          String?   @map("expense_id")
  budgetAllocationId String?   @map("budget_allocation_id")
  valor              Int // centavos
  tipo               String // RECEBIMENTO | DESPESA
  data               DateTime
  categoria          String // para recebimento: tipo do recebimento; para despesa: tipoDespesa
  subcategoria       String? // para despesa de mão de obra: categoriaMaoDeObra
  ambiente           String? // nome do room (denormalizado para exibição)
  formaPagamento     String?   @map("forma_pagamento")
  status             String // PAGO | PLANEJADO | PREVISTO | EM_CAIXA
  parcela            String? // ex: "1/3", "2/3"
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  project          Project           @relation(fields: [projectId], references: [id])
  receipt          Receipt?          @relation(fields: [receiptId], references: [id])
  expense          Expense?          @relation(fields: [expenseId], references: [id])
  budgetAllocation BudgetAllocation? @relation(fields: [budgetAllocationId], references: [id])

  @@index([projectId, data])
  @@index([receiptId])
  @@index([expenseId])
  @@index([budgetAllocationId])
  @@map("cash_flow_entries")
}

model Attachment {
  id         String    @id @default(cuid())
  entityType String    @map("entity_type")
  entityId   String    @map("entity_id")
  fileName   String    @map("file_name")
  mimeType   String    @map("mime_type")
  url        String
  uploadedBy String    @map("uploaded_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  deletedAt  DateTime? @map("deleted_at")

  @@index([entityType, entityId])
  @@map("attachments")
}

model VehicleDocument {
  id                       String    @id @default(cuid())
  projectId                String    @map("project_id")
  tenantId                 String    @map("tenant_id")
  reminderId               String?   @unique @map("reminder_id")
  tipo                     String
  titulo                   String
  numero                   String?
  dataVencimento           DateTime  @map("data_vencimento")
  lembreteAntecedenciaDias Int       @default(30) @map("lembrete_antecedencia_dias")
  observacoes              String?
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")
  deletedAt                DateTime? @map("deleted_at")

  project  Project   @relation(fields: [projectId], references: [id])
  reminder Reminder? @relation(fields: [reminderId], references: [id], onDelete: SetNull)

  @@index([projectId, dataVencimento])
  @@index([tenantId])
  @@map("vehicle_documents")
}

model Simulation {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  tenantId  String   @map("tenant_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project           @relation(fields: [projectId], references: [id])
  values  SimulationValue[]

  @@map("simulations")
}

model SimulationValue {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  tenantId     String   @map("tenant_id")
  simulationId String?  @map("simulation_id")
  key          String
  valor        String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project    Project     @relation(fields: [projectId], references: [id])
  simulation Simulation? @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  @@unique([simulationId, projectId, tenantId, key])
  @@map("simulation_values")
}

// ─── Plantas Baixas ──────────────────────────────────────────

model FloorPlan {
  id         String    @id @default(cuid())
  projectId  String    @map("project_id")
  tenantId   String    @map("tenant_id")
  name       String
  imageUrl   String    @map("image_url") // path to uploaded image
  cropBounds String?   @map("crop_bounds") // JSON {x,y,width,height} em % — janela útil da imagem
  order      Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  project Project           @relation(fields: [projectId], references: [id])
  rooms   FloorPlanRoom[]
  markers FloorPlanMarker[]

  @@map("floor_plans")
}

model FloorPlanMarker {
  id          String   @id @default(cuid())
  floorPlanId String   @map("floor_plan_id")
  expenseId   String   @map("expense_id")
  bounds      String // JSON: {x, y, width, height} as percentages of image
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  floorPlan FloorPlan @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  expense   Expense   @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@map("floor_plan_markers")
}

model FloorPlanRoom {
  id          String   @id @default(cuid())
  floorPlanId String   @map("floor_plan_id")
  roomId      String?  @map("room_id") // linked to Room (ambiente)
  label       String // display name on the floor plan
  bounds      String // JSON: {x, y, width, height} as percentages of image
  color       String   @default("#3B82F6") // overlay color
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  floorPlan FloorPlan @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  room      Room?     @relation(fields: [roomId], references: [id])

  @@map("floor_plan_rooms")
}

model RoomImage {
  id        String   @id @default(cuid())
  roomId    String   @map("room_id")
  imageUrl  String   @map("image_url")
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("room_images")
}

// ─── Contas Recorrentes (CASA / CARRO) ──────────────────────

model RecurringBill {
  id                String    @id @default(cuid())
  projectId         String    @map("project_id")
  tenantId          String    @map("tenant_id")
  nome              String
  valor             Int // centavos
  categoria         String // LUZ | AGUA | INTERNET | IPTU | CONDOMINIO | SEGURO | GAS | TELEFONE | STREAMING | OUTRO
  frequencia        String    @default("MENSAL") // MENSAL | BIMESTRAL | TRIMESTRAL | SEMESTRAL | ANUAL
  diaVencimento     Int       @map("dia_vencimento") // 1-31
  status            String    @default("ATIVO") // ATIVO | PAUSADO
  ultimoPagamento   DateTime? @map("ultimo_pagamento")
  proximoVencimento DateTime? @map("proximo_vencimento")
  observacoes       String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@map("recurring_bills")
}

// ─── Manutenções (CASA / CARRO) ────────────────────────────

model MaintenanceLog {
  id            String    @id @default(cuid())
  projectId     String    @map("project_id")
  tenantId      String    @map("tenant_id")
  plantId       String?   @map("plant_id") // PLANTAS: vincula a manutenção a uma planta específica
  generatedBy   String?   @map("generated_by")
  tipo          String // CASA: PINTURA | IMPERMEABILIZACAO | DEDETIZACAO | LIMPEZA_CAIXA | REVISAO_ELETRICA | REVISAO_HIDRAULICA | OUTRO
  // CARRO: TROCA_OLEO | FILTRO_AR | FILTRO_OLEO | FILTRO_COMBUSTIVEL | PNEUS | ALINHAMENTO | BALANCEAMENTO | REVISAO | FREIOS | CORREIA | OUTRO
  // PLANTAS: REGA | ADUBACAO | PODA | TROCA_VASO | TRATAMENTO_PRAGA | OUTRO
  dataRealizada DateTime  @map("data_realizada")
  dataProxima   DateTime? @map("data_proxima")
  quilometragem Int? // só para CARRO
  custo         Int? // centavos
  fornecedor    String?
  observacoes   String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id])
  plant   Plant?  @relation(fields: [plantId], references: [id])

  @@index([projectId])
  @@index([plantId])
  @@map("maintenance_logs")
}

// ─── Financiamento (CASA) ────────────────────────────────────
// Singleton por projeto (@@unique projectId). A tabela de parcelas serve
// tanto para a projeção (status PREVISTO, gerada em lote pelo sistema
// PRICE/SAC) quanto para o histórico realmente pago (status PAGO).

model Financing {
  id                   String    @id @default(cuid())
  projectId            String    @unique @map("project_id")
  tenantId             String    @map("tenant_id")
  instituicao          String?
  sistema              String    @default("PRICE") // PRICE | SAC
  valorTotalFinanciado Int       @map("valor_total_financiado") // centavos
  taxaJurosMensalBps   Int       @map("taxa_juros_mensal_bps") // basis points (1% = 100)
  prazoMeses           Int       @map("prazo_meses")
  dataPrimeiraParcela  DateTime  @map("data_primeira_parcela")
  diaVencimento        Int       @map("dia_vencimento") // 1-31
  status               String    @default("ATIVO") // ATIVO | QUITADO
  observacoes          String?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  project      Project                @relation(fields: [projectId], references: [id])
  installments FinancingInstallment[]

  @@map("financings")
}

model FinancingInstallment {
  id                   String    @id @default(cuid())
  financingId          String    @map("financing_id")
  projectId            String    @map("project_id")
  tenantId             String    @map("tenant_id")
  numeroParcela        Int       @map("numero_parcela")
  dataVencimento       DateTime  @map("data_vencimento")
  valorPrevisto        Int       @map("valor_previsto") // centavos
  saldoDevedorPrevisto Int       @map("saldo_devedor_previsto") // centavos, após esta parcela
  status               String    @default("PREVISTO") // PREVISTO | PAGO
  valorPago            Int?      @map("valor_pago") // centavos
  dataPagamento        DateTime? @map("data_pagamento")
  // Espelha a parcela como despesa PLANEJADA avulsa no projeto dono (CASA/CARRO),
  // só dentro do horizonte rolling de 12 meses — alvo normal de vínculo/rateio do
  // PESSOAL (regras 14/15). Nulo = fora da janela, ainda não materializada.
  expenseId            String?   @unique @map("expense_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  financing Financing @relation(fields: [financingId], references: [id], onDelete: Cascade)
  expense   Expense?  @relation(fields: [expenseId], references: [id])

  @@unique([financingId, numeroParcela])
  @@index([projectId, dataVencimento])
  @@map("financing_installments")
}

// ─── Planejador de Compras (épico #271) ────────────────────
// Cenários hipotéticos (3/6/12 meses) sobre a projeção consolidada do
// PESSOAL — nunca um segundo motor financeiro. Cálculo em packages/domain
// (applyPurchasePlan), esta tabela só persiste a entrada do usuário.

model PurchaseScenario {
  id            String    @id @default(cuid())
  projectId     String    @map("project_id")
  tenantId      String    @map("tenant_id")
  nome          String
  horizonteMeses Int      @default(6) @map("horizonte_meses") // 3 | 6 | 12 (última escolha do usuário)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  project Project                @relation(fields: [projectId], references: [id])
  itens   PurchaseScenarioItem[]

  @@index([tenantId, projectId])
  @@map("purchase_scenarios")
}

model PurchaseScenarioItem {
  id                 String    @id @default(cuid())
  scenarioId         String    @map("scenario_id")
  projectId          String    @map("project_id")
  tenantId           String    @map("tenant_id")
  nome               String
  tipo               String    @map("tipo") // A_VISTA | PARCELADO | FINANCIAMENTO
  valorCents         Int       @map("valor_cents")
  entradaCents       Int?      @map("entrada_cents") // só FINANCIAMENTO
  parcelas           Int?      @map("parcelas") // PARCELADO | FINANCIAMENTO
  taxaJurosMensalBps Int?      @map("taxa_juros_mensal_bps") // só FINANCIAMENTO
  sistema            String?   @map("sistema") // PRICE | SAC, só FINANCIAMENTO
  mesInicio          String    @map("mes_inicio") // "YYYY-MM"
  incluido           Boolean   @default(true) @map("incluido") // toggle: OFF não afeta a série
  // Deep-link do item monitorado (COMPRA) que originou este item — pré-carrega
  // nome+preço na UI (PR-C). Sem cascade: apagar o monitoramento não apaga o
  // cenário, só perde a referência de origem.
  sourcePriceItemId  String?   @map("source_price_item_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  scenario       PurchaseScenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  sourcePriceItem PriceMonitorItem? @relation(fields: [sourcePriceItemId], references: [id])

  @@index([tenantId, projectId, scenarioId])
  @@map("purchase_scenario_items")
}

// ─── Lembretes ──────────────────────────────────────────────

model Reminder {
  id          String    @id @default(cuid())
  projectId   String    @map("project_id")
  tenantId    String    @map("tenant_id")
  plantId     String?   @map("plant_id") // PLANTAS: vincula o lembrete a uma planta específica
  generatedBy String?   @map("generated_by")
  titulo      String
  descricao   String?
  data        DateTime
  recorrencia String    @default("UNICA") // UNICA | DIARIA | SEMANAL | MENSAL | ANUAL
  status      String    @default("PENDENTE") // PENDENTE | CONCLUIDO | ADIADO
  prioridade  String    @default("MEDIA") // BAIXA | MEDIA | ALTA | URGENTE
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id])
  plant   Plant?  @relation(fields: [plantId], references: [id])
  vehicleDocument VehicleDocument?

  @@index([projectId])
  @@index([data])
  @@index([plantId])
  @@map("reminders")
}

// ─── Plantas (PLANTAS) ──────────────────────────────────────

model Plant {
  id                  String    @id @default(cuid())
  projectId           String    @map("project_id")
  tenantId            String    @map("tenant_id")
  nome                String // apelido dado pelo usuário (ex: "Jiboia da sala")
  localizacao         String?
  fotoUrl             String?   @map("foto_url") // foto de referência (última foto de diagnóstico)
  especiePopular      String?   @map("especie_popular")
  especieCientifica   String?   @map("especie_cientifica")
  ultimaSaude         String?   @map("ultima_saude") // SAUDAVEL | ATENCAO | CRITICA
  ultimoRiscoPet      String?   @map("ultimo_risco_pet") // SEGURO | CAUTELA | TOXICA | DESCONHECIDO
  ultimoDiagnosticoEm DateTime? @map("ultimo_diagnostico_em")
  observacoes         String?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  project     Project             @relation(fields: [projectId], references: [id])
  reminders   Reminder[]
  maintenance MaintenanceLog[]
  diagnoses   PlantDiagnosisLog[]

  @@index([projectId])
  @@map("plants")
}

model PlantDiagnosisLog {
  id                String   @id @default(cuid())
  plantId           String   @map("plant_id")
  projectId         String   @map("project_id")
  tenantId          String   @map("tenant_id")
  especiePopular    String?  @map("especie_popular")
  especieCientifica String?  @map("especie_cientifica")
  confiancaEspecie  Float?   @map("confianca_especie")
  saudeStatus       String?  @map("saude_status")
  saudeConfianca    Float?   @map("saude_confianca")
  riscoPet          String?  @map("risco_pet")
  diagnosisJson     String   @map("diagnosis_json") // resultado completo (JSON) retornado pelo Gemini
  createdAt         DateTime @default(now()) @map("created_at")

  plant Plant @relation(fields: [plantId], references: [id])

  @@index([plantId])
  @@index([projectId])
  @@map("plant_diagnosis_logs")
}

// ─── Cronograma de Obra ─────────────────────────────────────────

model ScheduleConfig {
  id                String    @id @default(cuid())
  projectId         String    @unique @map("project_id")
  tenantId          String    @map("tenant_id")
  dataInicio        DateTime  @map("data_inicio")
  trabalhaDiasUteis Boolean   @default(true) @map("trabalha_dias_uteis")
  trabalhaSabados   Boolean   @default(false) @map("trabalha_sabados")
  linhaBaseData     DateTime? @map("linha_base_data")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id])

  @@map("schedule_configs")
}

model ScheduleStage {
  id        String    @id @default(cuid())
  projectId String    @map("project_id")
  tenantId  String    @map("tenant_id")
  nome      String
  ordem     Int
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  project Project        @relation(fields: [projectId], references: [id])
  tasks   ScheduleTask[]

  @@index([projectId])
  @@map("schedule_stages")
}

model ScheduleTask {
  id                  String    @id @default(cuid())
  stageId             String    @map("stage_id")
  projectId           String    @map("project_id")
  tenantId            String    @map("tenant_id")
  numero              Int
  nome                String
  duracao             Int       @default(1) // dias
  dataInicio          DateTime? @map("data_inicio")
  dataTermino         DateTime? @map("data_termino")
  predecessoras       String? // JSON array de números de tarefas, ex: "[2,3]"
  valorOrcado         Int?      @map("valor_orcado") // centavos
  custoReal           Int?      @map("custo_real") // centavos
  percentualConcluido Float     @default(0) @map("percentual_concluido")
  ordem               Int
  dataInicioBase      DateTime? @map("data_inicio_base")
  dataTerminoBase     DateTime? @map("data_termino_base")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  stage      ScheduleStage @relation(fields: [stageId], references: [id])
  project    Project       @relation(fields: [projectId], references: [id])
  pendencias Pendencia[]

  @@index([stageId])
  @@index([projectId])
  @@map("schedule_tasks")
}

model ScheduleHoliday {
  id        String    @id @default(cuid())
  projectId String    @map("project_id")
  tenantId  String    @map("tenant_id")
  nome      String
  data      DateTime
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@map("schedule_holidays")
}

model Pendencia {
  id             String    @id @default(cuid())
  projectId      String    @map("project_id")
  tenantId       String    @map("tenant_id")
  title          String
  description    String?
  status         String    @default("PENDENTE")
  dueDate        DateTime? @map("due_date")
  owner          String?
  roomId         String?   @map("room_id")
  scheduleTaskId String?   @map("schedule_task_id")
  order          Int       @default(0)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  project      Project       @relation(fields: [projectId], references: [id])
  room         Room?         @relation(fields: [roomId], references: [id])
  scheduleTask ScheduleTask? @relation(fields: [scheduleTaskId], references: [id])

  @@index([projectId])
  @@index([roomId])
  @@index([scheduleTaskId])
  @@map("pendencias")
}

// ─── Cartões de crédito (import de fatura OFX/CSV) ─────────

model CreditCard {
  id                  String    @id @default(cuid())
  projectId           String    @map("project_id")
  tenantId            String    @map("tenant_id")
  institution         String // ITAU | NUBANC | INTER | BB | CAIXA | OUTROS
  brand               String    @default("Outros") // Visa | Mastercard | Elo | Amex | Hipercard | Outros
  nickname            String
  last4               String // últimos 4 dígitos. NUNCA salvar PAN completo.
  limitTotalCents     Int?      @map("limit_total_cents")
  limitAvailableCents Int?      @map("limit_available_cents")
  closingDay          Int?      @map("closing_day") // dia do mês do fechamento
  dueDay              Int?      @map("due_day") // dia do mês do vencimento
  notes               String?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  project Project                     @relation(fields: [projectId], references: [id])
  imports CreditCardStatementImport[]

  @@index([projectId])
  @@index([tenantId])
  @@map("credit_cards")
}

model CreditCardStatementImport {
  id               String    @id @default(cuid())
  cardId           String    @map("card_id")
  tenantId         String    @map("tenant_id")
  periodLabel      String    @map("period_label") // ex: "2026-05" (mês de referência da fatura)
  source           String // OFX | CSV_NUBANK | CSV_ITAU | CSV_GENERIC
  fileName         String?   @map("file_name")
  fileSize         Int?      @map("file_size")
  status           String    @default("COMPLETED") // PROCESSING | COMPLETED | FAILED
  inserted         Int       @default(0)
  duplicated       Int       @default(0)
  skipped          Int       @default(0)
  totalAmountCents Int       @default(0) @map("total_amount_cents")
  message          String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  card CreditCard @relation(fields: [cardId], references: [id])

  @@index([cardId])
  @@index([tenantId])
  @@map("credit_card_imports")
}

model InvoiceAdjustment {
  id          String                  @id @default(cuid())
  projectId   String                  @map("project_id")
  tenantId    String                  @map("tenant_id")
  cardLast4   String                  @map("card_last4")
  dueMonth    String                  @map("due_month")
  amountCents Int                     @map("amount_cents")
  reason      String
  note        String?
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")
  deletedAt   DateTime?               @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id])

  @@index([tenantId, projectId, dueMonth])
  @@index([tenantId, projectId, cardLast4, dueMonth])
  @@map("invoice_adjustments")
}

// ──────────────────────────────────────────────────────────────
// Bank Accounts (extratos bancários — débitos viram despesas pessoais)
// ──────────────────────────────────────────────────────────────

model BankAccount {
  id                  String    @id @default(cuid())
  projectId           String    @map("project_id")
  tenantId            String    @map("tenant_id")
  institution         String // ITAU | NUBANK | BRADESCO | SANTANDER | BB | CAIXA | INTER | C6 | OUTRO
  nickname            String
  agency              String? // agência (ex: 7057)
  accountNumber       String?   @map("account_number") // número formatado (ex: 077424-7)
  last4               String // últimos 4 dígitos do número (denormalizado, NUNCA o número completo se for sensível)
  notes               String?
  openingBalanceCents Int       @default(0) @map("opening_balance_cents") // saldo inicial da conta (centavos) na openingBalanceDate — base da reconciliação §10
  openingBalanceDate  DateTime? @map("opening_balance_date") // data de referência do saldo inicial (ex.: 31/12 do extrato)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  project Project               @relation(fields: [projectId], references: [id])
  imports BankStatementImport[]

  @@index([projectId])
  @@index([tenantId])
  @@map("bank_accounts")
}

model BankStatementImport {
  id               String    @id @default(cuid())
  accountId        String    @map("account_id")
  tenantId         String    @map("tenant_id")
  periodLabel      String    @map("period_label") // ex: "2026-05" (mês de referência do extrato)
  source           String // OFX | CSV_GENERIC | PDF
  fileName         String?   @map("file_name")
  fileSize         Int?      @map("file_size")
  status           String    @default("COMPLETED") // PROCESSING | COMPLETED | FAILED
  inserted         Int       @default(0)
  duplicated       Int       @default(0)
  skipped          Int       @default(0)
  totalAmountCents Int       @default(0) @map("total_amount_cents") // somatório de débitos (positivo)
  message          String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  account BankAccount @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([tenantId])
  @@map("bank_statement_imports")
}

// ─── Merchant categorization cache (global, sem tenant) ──────
// Cache de classificação de estabelecimento. A chave é o nome
// normalizado (lowercase, sem datas/números). Compartilhado entre tenants.

model MerchantCategory {
  id             String   @id @default(cuid())
  merchantKey    String   @unique @map("merchant_key") // chave normalizada (lowercase, alpha)
  merchantSample String   @map("merchant_sample") // exemplo original (para auditoria)
  category       String // taxonomia: alimentação | transporte | assinaturas | viagem | saúde | compras | educação | casa | moradia | servicos | beleza | pets | impostos | outros
  subcategory    String? // detalhe livre (ex: "restaurante", "posto combustível")
  source         String // REGEX | AI | MANUAL
  confidence     Float    @default(1.0)
  aiResponse     String?  @map("ai_response") // raw JSON do AI (debug)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("merchant_categories")
}

// ─── Budget Allocation (Envelope Budgeting) ───────────────────

model BudgetAllocation {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  // Source (always PESSOAL project)
  sourceProjectId String  @map("source_project_id")
  sourceReceiptId String? @map("source_receipt_id")

  // Target (REFORMA, CARRO, CASA, COMPRA)
  targetProjectId String @map("target_project_id")

  // Allocation details
  valor        Int // in cents
  descricao    String? // "Budget mensal Abril", "Extra reforma banheiro"
  mes          String // YYYY-MM (for monthly tracking)
  dataAlocacao DateTime @default(now()) @map("data_alocacao")

  // Metadata
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  sourceProject   Project         @relation("SourceAllocations", fields: [sourceProjectId], references: [id])
  sourceReceipt   Receipt?        @relation(fields: [sourceReceiptId], references: [id])
  targetProject   Project         @relation("TargetAllocations", fields: [targetProjectId], references: [id])
  cashFlowEntries CashFlowEntry[]

  @@index([tenantId, sourceProjectId])
  @@index([tenantId, targetProjectId])
  @@index([mes])
  @@map("budget_allocations")
}


model Feedback {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  username  String
  message   String
  rating    Int? // 1-5 estrelas, opcional (ex.: onboarding "quão fácil foi usar o app")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("feedbacks")
}

model UserActivityLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  action    String   // e.g. "expenses.create", "projects.delete"
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("user_activity_logs")
}
