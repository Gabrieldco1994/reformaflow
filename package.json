{
  "name": "reformaflow",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "pre-commit": "cd packages/domain && npx tsc --noEmit && cd ../../apps/api && npx tsc --noEmit && cd ../../apps/web && npx tsc --noEmit"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run pre-commit"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "prettier": "^3.3.0",
    "prisma": "^5.22.0",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "prisma": {
    "seed": "npx ts-node prisma/seed.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}
